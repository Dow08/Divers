{
  "name": "WF-07 — LIVRAISON GUMROAD",
  "nodes": [
    {
      "parameters": {
        "path": "gumroad-sale",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "6w7x8y9z-0a1b-2c3d-4e5f-6g7h8i9j0k1l",
      "name": "Webhook Gumroad Sale",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "expression": "{\n  \"buyer_email\": $json.purchaser.email,\n  \"buyer_name\": $json.purchaser.name,\n  \"product_id\": $json.product_id,\n  \"product_name\": $json.product.name,\n  \"license_key\": $json.license_key,\n  \"amount\": $json.price,\n  \"purchase_date\": new Date().toISOString()\n}",
        "options": {}
      },
      "id": "7x8y9z0a-1b2c-3d4e-5f6g-7h8i9j0k1l2m",
      "name": "Parse Sale Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [300, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "from",
              "value": "{{ $env.RESEND_FROM_EMAIL }}"
            },
            {
              "name": "to",
              "value": "{{ $json.buyer_email }}"
            },
            {
              "name": "subject",
              "value": "Votre achat: {{ $json.product_name }}"
            },
            {
              "name": "html",
              "value": "<p>Merci {{ $json.buyer_name }}!</p><p>Voici votre lien de téléchargement: <a href='{{ $json.download_url }}'>Télécharger</a></p><p>Clé de licence: {{ $json.license_key }}</p>"
            }
          ]
        }
      },
      "id": "8y9z0a1b-2c3d-4e5f-6g7h-8i9j0k1l2m3n",
      "name": "Delivery Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [550, 150]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://sheets.googleapis.com/v4/spreadsheets/{{ $env.GOOGLE_SHEETS_ID }}/values/gumroad-sales:append",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "values",
              "value": "[[\"{{ $json.purchase_date }}\", \"{{ $json.product_name }}\", \"{{ $json.amount }}\", \"{{ $json.buyer_email }}\"]]"
            }
          ]
        }
      },
      "id": "9z0a1b2c-3d4e-5f6g-7h8i-9j0k1l2m3n4o",
      "name": "Log Sale to Google Sheets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [550, 300]
    },
    {
      "parameters": {
        "waitValue": 604800
      },
      "id": "0a1b2c3d-4e5f-6g7h-8i9j-0k1l2m3n4o5p",
      "name": "Wait 7 Days",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [800, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "from",
              "value": "{{ $env.RESEND_FROM_EMAIL }}"
            },
            {
              "name": "to",
              "value": "{{ $json.buyer_email }}"
            },
            {
              "name": "subject",
              "value": "Votre avis sur {{ $json.product_name }}"
            },
            {
              "name": "html",
              "value": "<p>Bonjour {{ $json.buyer_name }},</p><p>Comment trouvez-vous {{ $json.product_name }}? Vos retours nous aident!</p><p><a href='{{ $env.FEEDBACK_FORM_URL }}'>Donner mon avis</a></p><p>Découvrez aussi nos autres produits...</p>"
            }
          ]
        }
      },
      "id": "1b2c3d4e-5f6g-7h8i-9j0k-1l2m3n4o5p6q",
      "name": "Follow-up Email J+7",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1000, 300]
    }
  ],
  "connections": {
