# ============================================================
# NEXUS CONFORMITÉ — Template de configuration
# ⚠️  Copier ce fichier en .env et remplir les valeurs réelles
#     cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# N8N — Configuration locale
# Interface : http://localhost:5678
# ------------------------------------------------------------
N8N_BASIC_AUTH_USER=nexus
N8N_BASIC_AUTH_PASSWORD=your_strong_password_here
N8N_ENCRYPTION_KEY=generate_a_random_32_char_string_here
N8N_PORT=5678

# N8N — Identifiants de connexion (utilisés par setup-n8n-credentials.js et import-workflows.js)
# Ce sont les identifiants créés lors du premier lancement de N8N (écran d'inscription)
N8N_LOGIN_EMAIL=your_n8n_login_email@example.com
N8N_LOGIN_PASSWORD=your_n8n_login_password_here

# API Key N8N — Créer dans Settings > n8n API > Create an API Key
# Utilisée par WF-01 Backup (header X-N8N-API-KEY)
N8N_API_KEY=your_n8n_api_key_here

# ------------------------------------------------------------
# BREVO (ex-Sendinblue) — SMTP cold email (300/j gratuit)
# Obtenir : https://app.brevo.com/settings/keys/smtp
# ------------------------------------------------------------
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_brevo_login@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-your_brevo_smtp_key_here

# ------------------------------------------------------------
# BEEHIIV — Newsletter
# Obtenir : https://app.beehiiv.com/settings/api
# ------------------------------------------------------------
BEEHIIV_PUBLICATION_ID=pub_your_publication_id_here
BEEHIIV_API_KEY=your_beehiiv_api_key_here

# ------------------------------------------------------------
# TELEGRAM BOT — Alertes revenus temps réel
# Créer le bot : Telegram → @BotFather → /newbot
# Chat ID : https://api.telegram.org/botYOUR_TOKEN/getUpdates
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ------------------------------------------------------------
# ANTHROPIC — Claude API (optionnel, remplacé par Gemini)
# Obtenir : https://console.anthropic.com/settings/keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ------------------------------------------------------------
# GOOGLE GEMINI — IA générative gratuite (1 500 req/jour)
# Obtenir : https://aistudio.google.com/app/apikey
# Modèle : gemini-2.0-flash
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# STRIPE — Paiements et webhooks
# Obtenir : https://dashboard.stripe.com/test/apikeys
# Webhook : https://dashboard.stripe.com/test/webhooks
# ------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=STRIPE_TEST_KEY_REMOVED_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ------------------------------------------------------------
# ADMIN — Email de l'administrateur NEXUS (alertes internes)
# Reçoit les copies des leads WF-06 et alertes WF-07
# ------------------------------------------------------------
ADMIN_EMAIL=votre_email_admin@example.com

# ------------------------------------------------------------
# GOOGLE SHEETS — Dashboard revenus (NEXUS-REVENUS)
# Récupérer l'ID dans l'URL du Sheet (entre /d/ et /edit)
# Exemple URL : docs.google.com/spreadsheets/d/1aBcD...xYz/edit
# → GOOGLE_SHEETS_ID=1aBcD...xYz
# ------------------------------------------------------------
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ------------------------------------------------------------
# WORDPRESS — API pour création articles automatique
# Admin → Utilisateurs → Profil → Mots de passe d'application
# ------------------------------------------------------------
WORDPRESS_URL=https://your-domain.fr
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_APP_PASSWORD=your_wp_application_password_here

# ------------------------------------------------------------
# GUMROAD — Webhooks livraison produits numériques
# Configurer : https://app.gumroad.com/settings/advanced
# ------------------------------------------------------------
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret_here
