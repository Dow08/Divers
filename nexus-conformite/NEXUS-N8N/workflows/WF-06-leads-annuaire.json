    "Parser données du lead": {
      "main": [
        [
          {
            "node": "Email — Confirmation au prospect",
            "type": "main",
            "index": 0
          },
          {
            "node": "Email — Notifier admin",
            "type": "main",
            "index": 0
          },
          {
            "node": "Sheets — Logger lead CRM",
            "type": "main",
            "index": 0
          },
          {
            "node": "Telegram — Nouveau lead",
