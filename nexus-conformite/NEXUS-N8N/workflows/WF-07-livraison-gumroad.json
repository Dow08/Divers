   line-height: 1.6;\n        }\n        .tip-item strong {\n            color: #ff8c00;\n        }\n        .survey-box {\n            background-color: #e8f4f8;\n            border: 2px solid #ff8c00;\n            padding: 25px;\n            border-radius: 8px;\n            margin: 25px 0;\n            text-align: center;\n        }\n        .survey-box h3 {\n            color: #001f4d;\n            font-size: 18px;\n            margin-bottom: 15px;\n        }\n        .cta-button {\n            display: inline-block;\n            background-color: #ff8c00;\n            color: white;\n            padding: 12px 30px;\n            text-decoration: none;\n            border-radius: 4px;\n            font-weight: bold;\n            font-size: 14px;\n            margin: 10px 0;\n        }\n        .cta-button:hover {\n            background-color: #e67e00;\n        }\n        .upsell-section {\n            background-color: #f0f7ff;\n            border: 1px solid #b3d9e8;\n            padding: 20px;\n            border-radius: 4px;\n            margin: 25px 0;\n        }\n        .upsell-section h3 {\n            color: #001f4d;\n            font-size: 16px;\n            margin-bottom: 15px;\n        }\n        .upsell-item {\n            margin-bottom: 12px;\n            font-size: 13px;\n            color: #555;\n        }\n        .upsell-item strong {\n            color: #001f4d;\n        }\n        .support {\n            background-color: #e8f4f8;\n            border: 1px solid #b3d9e8;\n            padding: 15px;\n            border-radius: 4px;\n            margin: 25px 0;\n            font-size: 13px;\n            text-align: center;\n        }\n        .support strong {\n            color: #001f4d;\n            display: block;\n            margin-bottom: 5px;\n        }\n        .footer {\n            background-color: #f5f5f5;\n            padding: 25px 30px;\n            font-size: 12px;\n            color: #999;\n            text-align: center;\n            border-top: 1px solid #e0e0e0;\n        }\n        .footer-links {\n            margin-bottom: 15px;\n        }\n        .footer-links a {\n            color: #001f4d;\n            text-decoration: none;\n            margin: 0 10px;\n        }\n        .footer-links a:hover {\n            text-decoration: underline;\n        }\n        .company-info {\n            margin-top: 15px;\n            line-height: 1.6;\n            color: #777;\n        }\n    </style>\n</head>\n<body>\n    <table class=\"container\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1); overflow: hidden;\">\n        <!-- HEADER -->\n        <tr>\n            <td class=\"header\" style=\"background: linear-gradient(135deg, #001f4d 0%, #003d7a 100%); color: white; padding: 40px 20px; text-align: center;\">\n                <div style=\"font-size: 48px; margin-bottom: 10px;\">🎯</div>\n                <h1 style=\"font-size: 28px; margin-bottom: 10px; font-weight: bold; color: white;\">Comment se passe votre mise en conformité ?</h1>\n                <p style=\"margin: 0; font-size: 16px;\">Une semaine déjà !</p>\n            </td>\n        </tr>\n\n        <!-- CONTENT -->\n        <tr>\n            <td style=\"padding: 40px 30px;\">\n                <p class=\"greeting\" style=\"font-size: 18px; color: #001f4d; margin-bottom: 20px; font-weight: bold;\">Bonjour [PRENOM],</p>\n\n                <p class=\"text-block\" style=\"font-size: 14px; line-height: 1.6; color: #555; margin-bottom: 20px;\">\n                    Merci d'avoir choisi NEXUS CONFORMITÉ ! Une semaine a passé depuis votre achat du kit [NOM_PRODUIT].\n                    Nous espérons que vous avez trouvé les ressources utiles pour débuter votre mise en conformité.\n                </p>\n\n                <!-- SATISFACTION SURVEY -->\n                <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width: 100%; background-color: #e8f4f8; border: 2px solid #ff8c00; padding: 25px; border-radius: 8px; margin: 25px 0; text-align: center;\">\n                    <tr>\n                        <td>\n                            <h3 style=\"color: #001f4d; font-size: 18px; margin-bottom: 15px;\">📋 Votre avis nous intéresse !</h3>\n                            <p style=\"font-size: 13px; color: #555; margin-bottom: 15px;\">Aidez-nous à améliorer nos services en répondant à un court sondage (2 min)</p>\n                            <a href=\"[LIEN_SONDAGE]\" style=\"display: inline-block; background-color: #ff8c00; color: white; padding: 12px 30px; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 14px; margin: 10px 0;\">Répondre au sondage</a>\n                        </td>\n                    </tr>\n                </table>\n\n                <!-- TIPS SECTION -->\n                <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width: 100%; background-color: #fef9f0; border-left: 4px solid #ff8c00; padding: 20px; margin: 25px 0; border-radius: 4px;\">\n                    <tr>\n                        <td>\n                            <h3 style=\"color: #001f4d; font-size: 16px; margin-bottom: 15px;\">💡 Conseils pour utiliser au mieux votre kit</h3>\n\n                            <div style=\"margin-bottom: 15px; font-size: 13px; color: #555; line-height: 1.6;\">\n                                <strong style=\"color: #ff8c00;\">Tip #1 - Commencez simple</strong><br>\n                                Ne cherchez pas à mettre en œuvre tous les processus à la fois. Commencez par les points les plus critiques pour votre activité.\n                            </div>\n\n                            <div style=\"margin-bottom: 15px; font-size: 13px; color: #555; line-height: 1.6;\">\n                                <strong style=\"color: #ff8c00;\">Tip #2 - Impliquez votre équipe</strong><br>\n                                La conformité est un processus collectif. Partagez les ressources et checklist avec vos collaborateurs.\n                            </div>\n\n                            <div style=\"margin-bottom: 15px; font-size: 13px; color: #555; line-height: 1.6;\">\n                                <strong style=\"color: #ff8c00;\">Tip #3 - Documentez vos progrès</strong><br>\n                                Utilisez les templates fournis pour documenter vos démarches. C'est essentiel en cas de contrôle.\n                            </div>\n\n                            <div style=\"font-size: 13px; color: #555; line-height: 1.6;\">\n                                <strong style=\"color: #ff8c00;\">Tip #4 - Révisez régulièrement</strong><br>\n                                Les réglementations changent. Révisez vos procédures tous les trimestres pour rester à jour.\n                            </div>\n                        </td>\n                    </tr>\n                </table>\n\n                <!-- UPSELL SECTION -->\n                <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width: 100%; background-color: #f0f7ff; border: 1px solid #b3d9e8; padding: 20px; border-radius: 4px; margin: 25px 0;\">\n                    <tr>\n                        <td>\n                            <h3 style=\"color: #001f4d; font-size: 16px; margin-bottom: 15px;\">📚 Explorez nos autres ressources</h3>\n\n                            <div style=\"margin-bottom: 12px; font-size: 13px; color: #555;\">\n                                <strong style=\"color: #001f4d;\">📖 L'Annuaire des Ressources NEXUS</strong><br>\n                                Accédez à plus de 200 modèles, templates et guides de conformité pour tous les domaines.\n                                <br><a href=\"[LIEN_ANNUAIRE]\" style=\"color: #ff8c00; font-weight: bold; text-decoration: none;\">Découvrir l'annuaire</a>\n                            </div>\n\n                            <div style=\"margin-bottom: 12px; font-size: 13px; color: #555;\">\n                                <strong style=\"color: #001f4d;\">📧 Notre Newsletter Conformité</strong><br>\n                                Recevez chaque semaine des tips, actualités et exemples concrets de mise en conformité.\n                                <br><a href=\"[LIEN_NEWSLETTER]\" style=\"color: #ff8c00; font-weight: bold; text-decoration: none;\">S'abonner à la newsletter</a>\n                            </div>\n\n                            <div style=\"font-size: 13px; color: #555;\">\n                                <strong style=\"color: #001f4d;\">🎓 Webinaires & Formations</strong><br>\n                                Participez à nos sessions en ligne pour approfondir vos connaissances en conformité.\n                                <br><a href=\"[LIEN_WEBINAIRES]\" style=\"color: #ff8c00; font-weight: bold; text-decoration: none;\">Voir les formations</a>\n                            </div>\n                        </td>\n                    </tr>\n                </table>\n\n                <!-- SUPPORT -->\n                <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width: 100%; background-color: #e8f4f8; border: 1px solid #b3d9e8; padding: 15px; border-radius: 4px; margin: 25px 0; font-size: 13px; text-align: center;\">\n                    <tr>\n                        <td>\n                            <strong style=\"color: #001f4d; display: block; margin-bottom: 5px;\">❓ Besoin d'aide ?</strong>\n                            N'hésitez pas à nous contacter : <a href=\"mailto:contact@nexusconformite.fr\" style=\"color: #001f4d; text-decoration: none;\">contact@nexusconformite.fr</a>\n                        </td>\n                    </tr>\n                </table>\n\n                <p class=\"text-block\" style=\"font-size: 14px; line-height: 1.6; color: #555; margin-bottom: 20px;\">\n                    Nous sommes là pour vous soutenir à chaque étape de votre parcours de