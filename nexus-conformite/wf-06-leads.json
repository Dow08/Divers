{
  "name": "WF-06 — SUIVI LEADS",
  "nodes": [
    {
      "parameters": {
        "path": "contact-form",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "9p0q1r2s-3t4u-5v6w-7x8y-9z0a1b2c3d4e",
      "name": "Webhook Contact Form",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "expression": "{\n  \"company\": $json.company,\n  \"email\": $json.email,\n  \"phone\": $json.phone,\n  \"service_type\": $json.service_type,\n  \"message\": $json.message,\n  \"submitted_at\": new Date().toISOString()\n}",
        "options": {}
      },
      "id": "0q1r2s3t-4u5v-6w7x-8y9z-0a1b2c3d4e5f",
      "name": "Parse Form Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [300, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://sheets.googleapis.com/v4/spreadsheets/{{ $env.GOOGLE_SHEETS_ID }}/values/crm:append",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "values",
              "value": "[[\"{{ $json.submitted_at }}\", \"{{ $json.company }}\", \"{{ $json.email }}\", \"{{ $json.phone }}\", \"{{ $json.service_type }}\", \"pending\"]]"
            }
          ]
        }
      },
      "id": "1r2s3t4u-5v6w-7x8y-9z0a-1b2c3d4e5f6g",
      "name": "Log to Google Sheets CRM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [550, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "from",
              "value": "{{ $env.RESEND_FROM_EMAIL }}"
            },
            {
              "name": "to",
              "value": "{{ $env.PROVIDER_EMAIL_FOR_SERVICE_TYPE }}",
              "description": "Would be dynamic based on service_type"
            },
            {
              "name": "subject",
              "value": "Nouveau lead: {{ $json.company }}"
            },
            {
              "name": "html",
              "value": "<p>Nouvelle demande de {{ $json.company }}</p><p>Email: {{ $json.email }}</p><p>Téléphone: {{ $json.phone }}</p><p>Message: {{ $json.message }}</p>"
            }
          ]
        }
      },
      "id": "2s3t4u5v-6w7x-8y9z-0a1b-2c3d4e5f6g7h",
      "name": "Email Provider",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [550, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "from",
              "value": "{{ $env.RESEND_FROM_EMAIL }}"
            },
            {
              "name": "to",
              "value": "{{ $json.email }}"
            },
            {
              "name": "subject",
              "value": "Merci de votre demande"
            },
            {
              "name": "html",
              "value": "<p>Bonjour {{ $json.company }},</p><p>Nous avons bien reçu votre demande. Un prestataire vous contactera rapidement.</p>"
            }
          ]
        }
      },
      "id": "3t4u5v6w-7x8y-9z0a-1b2c-3d4e5f6g7h8i",
      "name": "Confirmation Email to Company",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [550, 500]
    },
    {
      "parameters": {
        "waitValue": 172800
      },
      "id": "4u5v6w7x-8y9z-0a1b-2c3d-4e5f6g7h8i9j",
      "name": "Wait 48 Hours",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [800, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "from",
              "value": "{{ $env.RESEND_FROM_EMAIL }}"
            },
            {
              "name": "to",
              "value": "{{ $env.PROVIDER_EMAIL_FOR_SERVICE_TYPE }}"
            },
            {
              "name": "subject",
              "value": "Relance: Lead {{ $json.company }}"
            },
            {
              "name": "html",
              "value": "<p>Rappel: Un lead en attente de réponse pour {{ $json.company }}</p>"
            }
          ]
        }
      },
      "id": "5v6w7x8y-9z0a-1b2c-3d4e-5f6g7h8i9j0k",
      "name": "Reminder to Provider",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1000, 300]
    }
  ],
