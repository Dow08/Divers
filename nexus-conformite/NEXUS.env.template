# ============================================================
# NEXUS CONFORMITÉ — Variables d'environnement N8N
# Fichier : NEXUS.env.template
# Instructions : Renommer en .env, remplir toutes les valeurs,
#                importer dans N8N > Settings > Variables
# ============================================================

# -----------------------------------------------------------
# 🤖 ANTHROPIC / CLAUDE API
# Source : https://console.anthropic.com > API Keys
# Créer une clé "nexus-conformite-n8n"
# Configurer dans N8N : Settings > Credentials > New > Bearer Token
# Nom de la credential N8N : "Anthropic Claude Haiku"
# -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------
# 📱 TELEGRAM BOT (alertes temps réel)
# Source : https://t.me/BotFather — commande /newbot
# Nom suggéré : NexusConformiteBot
# Obtenir CHAT_ID : envoyer /start au bot puis appeler
#   https://api.telegram.org/bot{TOKEN}/getUpdates
# -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff01234567890
TELEGRAM_CHAT_ID=987654321

# -----------------------------------------------------------
# 💬 SLACK WEBHOOKS (escalades support + alertes prix)
# Source : https://api.slack.com/apps > Incoming Webhooks
# Créer 2 webhooks différents :
#   - #support (pour WF-10 escalades email)
#   - #alertes (pour WF-11 changements prix)
# -----------------------------------------------------------
SLACK_WEBHOOK=T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_ALERTS=T00000000/B00000001/YYYYYYYYYYYYYYYYYYYYYYYY

# -----------------------------------------------------------
# 📧 RESEND (emails transactionnels)
# Source : https://resend.com > API Keys
# Vérifier le domaine nexusconformite.fr dans Resend
# -----------------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=support@nexusconformite.fr

# -----------------------------------------------------------
# 📨 BREVO SMTP (cold email B2B — 300/jour gratuit)
# Source : https://app.brevo.com > SMTP & API > SMTP Keys
# Activer le tracking ouvertures dans les paramètres
# -----------------------------------------------------------
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=votre-email@gmail.com
BREVO_SMTP_PASS=xsmtpib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BREVO_FROM_EMAIL=contact@nexusconformite.fr
BREVO_FROM_NAME=Nexus Conformité

# -----------------------------------------------------------
# 📰 BEEHIIV NEWSLETTER
# Source : https://app.beehiiv.com > Settings > Integrations > API
# Publication ID visible dans l'URL du dashboard
# -----------------------------------------------------------
BEEHIIV_API_KEY=bh-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BEEHIIV_PUB_ID=pub_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------
# 📊 GOOGLE SHEETS (CRM + revenus + tickets + pricing)
# Source : Google Cloud Console > APIs > Sheets API
# Créer un compte de service, télécharger JSON, configurer
# dans N8N > Credentials > Google Sheets OAuth2
# Un seul Google Sheet avec plusieurs onglets :
#   - Onglet "Tickets"   (WF-10 support)
#   - Onglet "Pricing"   (WF-11 prix concurrents)
#   - Onglet "Revenus"   (WF-04 Stripe)
#   - Onglet "Leads"     (WF-06 mise en relation)
#   - Onglet "Ventes"    (WF-07 Gumroad)
#   - Onglet "ColdEmail" (WF-09 cold emails)
#   - Onglet "Veille"    (WF-03 newsletter sources)
# -----------------------------------------------------------
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
SHEETS_ID_SUPPORT=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
SHEETS_ID_PRICING=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# -----------------------------------------------------------
# 💾 GOOGLE DRIVE BACKUPS
# Source : même compte de service que Google Sheets
# Créer un dossier "NEXUS-BACKUPS" dans Drive, copier l'ID
# (visible dans l'URL : drive.google.com/drive/folders/XXXXX)
# -----------------------------------------------------------
GOOGLE_DRIVE_BACKUP_FOLDER=1A2B3C4D5E6F7G8H9I0J1K2L3M4N5O6P

# -----------------------------------------------------------
# 🌐 WORDPRESS API
# Source : WordPress > Users > Profile > Application Passwords
# Créer un mot de passe applicatif pour l'utilisateur admin
# L'URL de base est https://nexusconformite.fr
# -----------------------------------------------------------
WP_API_URL=https://nexusconformite.fr
WP_AUTH_USER=admin
WP_AUTH_TOKEN=xxxx xxxx xxxx xxxx xxxx xxxx
WP_DIRECTORY_CATEGORY=prestataires-conformite

# -----------------------------------------------------------
# ⚙️  N8N INTERNE (workflow WF-01 backup)
# Source : N8N > Settings > API > Create Key
# L'URL est celle de votre instance N8N (après déploiement VPS)
# -----------------------------------------------------------
N8N_API_URL=https://n8n.nexusconformite.fr
N8N_API_KEY=n8n_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
N8N_INSTANCE_ID=nexus-conformite-prod

# -----------------------------------------------------------
# 🔔 STRIPE (webhooks paiements)
# Source : https://dashboard.stripe.com > Developers > Webhooks
# Créer un endpoint : https://n8n.nexusconformite.fr/webhook/stripe
# Événements à écouter : payment_intent.succeeded, customer.subscription.created
# -----------------------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_REMOVED

# -----------------------------------------------------------
# 🛒 GUMROAD (webhook ventes kits)
# Source : https://app.gumroad.com > Settings > Advanced > Ping URL
# Configurer : https://n8n.nexusconformite.fr/webhook/gumroad
# -----------------------------------------------------------
GUMROAD_APPLICATION_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GUMROAD_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------
# 📋 URLS INTERNES
# -----------------------------------------------------------
FEEDBACK_FORM_URL=https://nexusconformite.fr/feedback
PROVIDER_EMAIL_FOR_RGPD=expert-rgpd@nexusconformite.fr
PROVIDER_EMAIL_FOR_NIS2=expert-nis2@nexusconformite.fr
PROVIDER_EMAIL_FOR_FACTURATION=expert-facturation@nexusconformite.fr
PROVIDER_EMAIL_FOR_SERVICE_TYPE=contact@nexusconformite.fr

# ============================================================
# 📌 CHECKLIST AVANT MISE EN PRODUCTION
# ============================================================
# [ ] Tous les champs ci-dessus sont remplis avec de vraies valeurs
# [ ] ANTHROPIC_API_KEY importée dans N8N Credentials (pas dans .env)
# [ ] GOOGLE_SHEETS_ID pointe vers le bon fichier Sheets
# [ ] Domaine nexusconformite.fr vérifié dans Resend (SPF + DKIM)
# [ ] Telegram bot testé (envoi message test manuellement)
# [ ] WP Application Password créé et testé
# [ ] Stripe webhook endpoint activé et secret copié
# [ ] Fichier .env jamais commité dans git (vérifier .gitignore)
# ============================================================
