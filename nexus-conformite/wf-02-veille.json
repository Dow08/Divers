    {
      "parameters": {
        "method": "GET",
        "url": "https://eur-lex.europa.eu/rss/eurlex-new.rss",
        "options": {}
      },
      "id": "5e6f7g8h-9i0j-1k2l-3m4n-5o6p7q8r9s0t",
      "name": "Fetch EUR-Lex RSS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        300,
        650
      ]
    },
    {
      "parameters": {
        "expression": "{\n  \"articles\": $json,\n  \"filtered\": $json.filter(item => {\n    const text = (item.title + ' ' + item.description).toLowerCase();\n    const keywords = ['facturation', 'nis2', 'rgpd', 'comptabilité', 'conformité'];\n    return keywords.some(kw => text.includes(kw));\n  })\n}",
        "options": {}
      },
      "id": "6f7g8h9i-0j1k-2l3m-4n5o-6p7q8r9s0t1u",
      "name": "Filter Keywords",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [
        550,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "bearerToken",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-haiku-4-5-20251001"
            },
            {
              "name": "max_tokens",
              "value": "150"
            },
            {
              "name": "messages",
              "value": "[{\"role\": \"user\", \"content\": \"Résume en moins de 150 tokens: {{ $json.filtered[0].title }} - {{ $json.filtered[0].description }}\"}]"
            }
          ]
        },
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "7g8h9i0j-1k2l-3m4n-5o6p-7q8r9s0t1u2v",
      "name": "Claude Haiku Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        750,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/sendMessage",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
              "value": "{{ $env.TELEGRAM_CHAT_ID }}"
            },
            {
              "name": "text",
              "value": "🚨 Nouvelle réglementation: {{ $json.filtered[0].title }}"
            }
          ]
        }
      },
      "id": "8h9i0j1k-2l3m-4n5o-6p7q-8r9s0t1u2v3w",
      "name": "Telegram Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        950,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $env.WP_API_URL }}/wp-json/wp/v2/posts",
        "authentication": "genericCredentialType",
        "genericAuthType": "basicAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "{{ $json.filtered[0].title }}"
            },
            {
              "name": "content",
              "value": "{{ $json.filtered[0].description }}"
            },
            {
              "name": "status",
              "value": "draft"
            }
          ]
        }
      },
      "id": "9i0j1k2l-3m4n-5o6p-7q8r-9s0t1u2v3w4x",
      "name": "Create WordPress Draft",
      "type": "n8n-nodes-base.httpRequest",
